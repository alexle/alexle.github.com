---
layout: null
---
[
  {% for post in site.posts %}
  {
    "title": "{{ post.title | escape }}",
    "url": "{{ site.baseurl }}{{ post.url }}",
    "date": "{{ post.date | date: '%B %d, %Y' }}",
    "content": {{ post.content | strip_html | truncatewords: 50 | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
